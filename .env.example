# Flask app
FLASK_ENV=production
CORS_ORIGINS=http://localhost:5001,http://127.0.0.1:5001,http://localhost:3000,http://127.0.0.1:3000

# Protects /admin. Leave unset to disable the admin page.
ADMIN_TOKEN=change_this_admin_token

# Optional MongoDB persistence. If unset, the Flask app uses CSV-only mode.
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mood_app
MONGODB_DB=mood_app

# Optional TMDb catalog pipeline.
TMDB_API_KEY=your_tmdb_api_key

# Optional OpenAI mood classification path.
OPENAI_API_KEY=your_openai_api_key
