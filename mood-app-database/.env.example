# MongoDB Atlas Connection
# Replace with your actual connection string from Atlas
MONGODB_URI=mongodb+srv://moodapp_user:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/mood_app?retryWrites=true&w=majority

# App Config
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=change_this_to_a_random_64_char_string
JWT_EXPIRES_IN=7d

# AI Model Config
MODEL_VERSION=v1.0.0
MODEL_PATH=/models/mood-model
